SECRET_KEY=change-me-to-random-string

POSTGRES_HOST=car-reviews-db.xxxxx.region.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=mycars
POSTGRES_USER=mycars
POSTGRES_PASSWORD=your-password

ALLOWED_HOSTS=localhost,127.0.0.1,backend,drivelog.live,www.drivelog.live

CORS_ALLOWED_ORIGINS=https://drivelog.live,https://www.drivelog.live
CSRF_TRUSTED_ORIGINS=https://drivelog.live,https://www.drivelog.live

DOMAIN=drivelog.live
CERTBOT_EMAIL=you@example.com
FRONTEND_URL=https://drivelog.live

# --- Почта через Brevo (https://app.brevo.com) ---
# 1) Settings → Senders, domains & IPs → Domains → Add drivelog.live → DNS
# 2) Settings → SMTP & API → SMTP → Generate SMTP key (НЕ API key!)
# 3) SMTP login — email, показанный на вкладке SMTP (часто ваш email аккаунта)
# Бесплатно: 300 писем/день
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=xsmtpsib-xxxxxxxx
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=DriveLog <noreply@drivelog.live>
