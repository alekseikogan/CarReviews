# Скопируйте в .env и заполните перед запуском на EC2
SECRET_KEY=change-me-to-random-string

POSTGRES_HOST=your-rds-endpoint.region.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=mycars
POSTGRES_USER=mycars
POSTGRES_PASSWORD=your-password

# Публичный IP или домен EC2 (через запятую, без пробелов)
ALLOWED_HOSTS=localhost,127.0.0.1,backend,3.120.45.67

# Обычно совпадает с http://<ваш-ip-или-домен>
CORS_ALLOWED_ORIGINS=http://3.120.45.67
